  author = {Del Pezzo, Edoardo and De La Torre, Angel and Bianco, Francesca and Ibanez, Jesús and Gabrielli, Simona and De Siena, Luca},
  date = {2018-05-11},
  journaltitle = {Geosciences},
  shortjournal = {Geosciences},
