@article{
  title = {Coda-{{Q}} in the 2.5–20 s Period Band from Seismic Noise: Application to the Greater {{Alpine}} Area},
  shorttitle = {Coda-{{Q}} in the 2.5–20 s Period Band from Seismic Noise},
  author = {Soergel, D and Pedersen, H A and Stehly, L and Margerin, L and Paul, A and {AlpArray Working Group}},
  date = {2020-01-01},
  journaltitle = {Geophysical Journal International},
